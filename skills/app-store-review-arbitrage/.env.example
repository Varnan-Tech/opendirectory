# .env.example — app-store-review-arbitrage

# No API keys are required to run this skill.
# All data collection uses free, public sources:
#   - App Store: app-store-scraper (pip package, no auth)
#   - Google Play: google-play-scraper (pip package, no auth)

# ─── Optional ────────────────────────────────────────────────────────────────

# HTTP_PROXY
# If you are behind a corporate proxy, set this to route outbound requests.
# Both app-store-scraper and google-play-scraper respect standard HTTP_PROXY
# and HTTPS_PROXY environment variables.
#
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# ─── Not needed ──────────────────────────────────────────────────────────────

# No OPENAI_API_KEY, ANTHROPIC_API_KEY, or any other key is required.
# LLM analysis uses the agent already running the skill.

# vps-deploy-playbook — Environment Variables
# =============================================
# Copy this file to .env in your project root before running the skill.
# NEVER commit .env to git.

# Required: VPS IP address or hostname (no protocol — just the raw IP or domain)
# Example: 72.62.229.16  or  vps.example.com
VPS_HOST=your_vps_ip_or_hostname

# Required: SSH username for the VPS
# Common values: root (Hostinger, DigitalOcean default), ubuntu (AWS EC2 default)
VPS_USER=root

# Required: Name of the Docker service / container
# This becomes the docker run --name value and the docker compose service key
# Use lowercase with dashes. Example: my-app, wandervault, notes-api
SERVICE_NAME=my-app

# Required: Base production domain (no protocol, no www)
# Example: myapp.com
# The skill will deploy:
#   master branch → test.myapp.com
#   main branch   → myapp.com
DOMAIN=myapp.com

# Required: Port your app listens on INSIDE the Docker container
# Next.js default: 3000   |   FastAPI default: 8000   |   Express default: 3000
APP_PORT=3000

# Optional: Absolute path on the VPS where the app lives
# Defaults to /opt/services/$SERVICE_NAME if not set
# Example: /opt/services/my-app
APP_DIR=/opt/services/my-app

# Optional: Email address for Let's Encrypt SSL certificate registration
# Defaults to admin@$DOMAIN if not set
# Let's Encrypt sends cert expiry reminders here
SSL_EMAIL=you@example.com
